# config/.env.example — copy to .env (gitignored) and fill at check-in.
# The venue tier is OPTIONAL — the safety loop never depends on it.

# Qualcomm Cloud AI 100 — AI Inference Suite (REST). Endpoint/model/key from
# organizers at 10:00 check-in. If unset, venue-tier auto-falls-back to
# template-local (badged honestly).
AISUITE_ENDPOINT=
AISUITE_KEY=
AISUITE_MODEL=

# Broker (override config/devices.yaml if needed).
MQTT_HOST=127.0.0.1
MQTT_PORT=1883

# Dashboard.
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
